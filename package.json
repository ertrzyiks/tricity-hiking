{
  "name": "astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "test": "vitest",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "capture": "concurrently \"PUBLIC_ASTRO_USE_MAPTILER_MAP_STYLE=true astro dev\" \"sleep 1 && node scripts/capture.js\" --kill-others",
    "capture:preview": "concurrently \"PUBLIC_ASTRO_USE_MAPTILER_MAP_STYLE=true astro dev\" \"sleep 1 && node scripts/capture-route-preview.js\" --kill-others",
    "capture:map-tiles": "concurrently \"PUBLIC_ASTRO_USE_MAPTILER_MAP_STYLE=true astro dev\" \"sleep 1 && node scripts/capture-map-assets.js\" --kill-others",
    "draft2route": "node scripts/draft-to-route.js",
    "gpx2json": "node scripts/gpx-to-json.js && prettier --write src/content/routes/*/*.json && prettier --write src/content/transportation/*.json",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/mdx": "4.3.14",
    "@astrojs/preact": "4.1.3",
    "@astrojs/sitemap": "3.7.2",
    "@iconify-json/mdi": "1.2.3",
    "@nanostores/preact": "1.1.0",
    "@piwikpro/tracking-base-library": "1.6.0",
    "@statsig/js-client": "3.32.3",
    "@statsig/session-replay": "3.32.3",
    "@statsig/web-analytics": "3.32.3",
    "@tailwindcss/vite": "4.2.2",
    "astro": "5.18.1",
    "astro-favicons": "3.1.6",
    "astro-icon": "1.1.5",
    "debounce": "3.0.0",
    "gantt-schedule-timeline-calendar": "3.41.7",
    "maplibre-gl": "4.7.1",
    "nanostores": "1.2.0",
    "playwright": "1.59.1",
    "preact": "10.29.1",
    "recharts": "3.8.1",
    "sharp": "0.34.5",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.3",
    "vanilla-cookieconsent": "3.1.0"
  },
  "devDependencies": {
    "@tmcw/togeojson": "5.8.1",
    "@xmldom/xmldom": "0.9.9",
    "concurrently": "8.2.2",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "puppeteer": "22.15.0",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "overrides": {
      "@iconify/tools": "4.2.0"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "puppeteer",
      "sharp"
    ]
  }
}
